generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model EquipmentTicket {
  id                   Int      @id @default(autoincrement())
  hubspotTicketId      String   @unique
  ticketName           String?  
  customerName         String?  
  companyName          String?  
  ownerName            String?  
  priority             String?  
  pipelineStage        String?  
  equipmentIssue       String
  stringTension        String?  // <-- NEW
  targetCompletionDate String?  // <-- NEW
  requiredParts        String?  // <-- NEW
  warrantyStatus       String?  // <-- NEW
  status               String   @default("Open")
  hubspotSyncStatus    String   @default("SYNCED") // SYNCED, FAILED, PENDING
  lastSyncError        String?
  occurredAt           DateTime
  createdAt            DateTime @default(now())
}